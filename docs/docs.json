  "seo": {
    "metatags": {
      "canonical": "https://docs.pandaprobe.com",
      "charset": "UTF-8",
      "viewport": "width=device-width, initial-scale=1.0",
      "description": "PandaProbe is an open-source agent engineering platform. Traces, evals, metrics, and live monitoring to debug and improve your AI agents.",
      "keywords": "PandaProbe, AI agents, agent engineering, agent observability, agent tracing, agent evaluation, OpenAI tracing, Anthropic tracing, Google Gemini tracing, LangGraph, CrewAI, Google ADK, Python SDK, open source, agent debugging, agent monitoring",
      "author": "Chirpz AI team",
      "robots": "index, follow",
      "googlebot": "index, follow",
      "google": "notranslate",
      "generator": "PandaProbe",
      "theme-color": "#18191b",
      "color-scheme": "light dark",
      "format-detection": "telephone=no",
      "referrer": "origin",
      "language": "en",
      "copyright": "Copyright 2026 Chirpz AI",
      "reply-to": "support@pandaprobe.com",
      "distribution": "global",
      "coverage": "Worldwide",
      "category": "Technology",
      "target": "developers",
      "HandheldFriendly": "True",
      "MobileOptimized": "320",
      "apple-mobile-web-app-capable": "yes",
      "apple-mobile-web-app-status-bar-style": "black-translucent",
      "apple-mobile-web-app-title": "PandaProbe Docs",
      "application-name": "PandaProbe",
      "msapplication-TileColor": "#18191b",
      "og:type": "website",
      "og:image": "https://docs.pandaprobe.com/assets/og-image-docs.png",
      "og:site_name": "PandaProbe Documentation",
      "og:locale": "en_US",
      "twitter:card": "summary_large_image",
      "twitter:site": "@pandaprobe",
      "twitter:creator": "@pandaprobe",
      "twitter:image": "https://docs.pandaprobe.com/assets/og-image-docs.png",
      "twitter:image:alt": "PandaProbe logo - open source agent engineering platform"
    }
  }
