{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "linden",
  "name": "PandaProbe",
  "logo": {
    "light": "/assets/logo/light.png",
    "dark": "/assets/logo/dark.png"
  },
  "favicon": "/assets/logo/favicon.ico",
