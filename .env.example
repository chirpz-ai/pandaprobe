# =============================================================================
# Opentracer – Environment Configuration
# =============================================================================
# Copy this file to .env.development (or .env.production, etc.) and fill in
# the values below.

# -- Application --------------------------------------------------------------
APP_ENV=development
DEBUG=true
PROJECT_NAME=Opentracer
VERSION=0.1.0
API_V1_PREFIX=/v1
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# -- PostgreSQL ----------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=opentracer_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=10

# -- Redis / Celery ------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# -- Evaluation LLM (for judge calls) ------------------------------------------
EVAL_LLM_PROVIDER=openai
EVAL_LLM_MODEL=gpt-4o-mini
EVAL_LLM_API_KEY=your-openai-api-key
EVAL_LLM_BASE_URL=
EVAL_LLM_TEMPERATURE=0.0

# -- Logging -------------------------------------------------------------------
LOG_LEVEL=DEBUG
LOG_FORMAT=console
