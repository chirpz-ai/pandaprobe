# =============================================================================
# Opentracer – Environment Configuration
# =============================================================================
# Copy this file to .env.development (or .env.production, etc.) and fill in
# the values below.

# -- Application --------------------------------------------------------------
APP_ENV=development
DEBUG=true
PROJECT_NAME=Opentracer
VERSION=0.1.0
API_V1_PREFIX=/v1
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# -- Authentication -----------------------------------------------------------
# "supabase" = Supabase Auth
# "firebase" = Firebase Admin SDK (uses GOOGLE_CLOUD_PROJECT)
AUTH_PROVIDER=supabase

# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
APP_SECRET_KEY=
APP_JWT_EXPIRY_HOURS=12

# Required when AUTH_PROVIDER=supabase
# URL: Supabase dashboard → Project Settings → API → Project URL
# Key: Supabase dashboard → Project Settings → API → Secret key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=

# -- PostgreSQL ----------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=opentracer_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=10

# -- Redis / Celery ------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# -- LLM Provider Credentials --------------------------------------------------
# Only fill in the providers you want to use.  The service works with
# whichever credentials are present and returns a clear message for the rest.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_CLOUD_PROJECT=
VERTEX_AI_LOCATION=us-central1

# -- Evaluation LLM defaults --------------------------------------------------
# Model string uses LiteLLM format: "<provider>/<model>"
# Examples: openai/gpt-4o-mini, anthropic/claude-3-5-sonnet-20241022,
#           gemini/gemini-2.0-flash, vertex_ai/gemini-pro
EVAL_LLM_MODEL=vertex_ai/gemini-2.5-flash
EVAL_LLM_TEMPERATURE=0.0

# -- Logging -------------------------------------------------------------------
LOG_LEVEL=DEBUG
LOG_FORMAT=console
