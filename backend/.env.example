# =============================================================================
# PandaProbe – Environment Configuration
# =============================================================================
# Copy this file to .env.development (or .env.production, etc.) and fill in
# the values below.

# -- Application --------------------------------------------------------------
APP_ENV=development
DEBUG=true
PROJECT_NAME=PandaProbe
VERSION=0.1.0
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# -- Authentication -----------------------------------------------------------
# "supabase" = Supabase Auth
# "firebase" = Firebase Admin SDK (uses GOOGLE_CLOUD_PROJECT)
AUTH_PROVIDER=supabase

# Required when AUTH_PROVIDER=supabase
# URL: Supabase dashboard → Project Settings → API → Project URL
# Key: Supabase dashboard → Project Settings → API → Secret key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=

# -- PostgreSQL ----------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=pandaprobe_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=5

# -- Redis / Celery ------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# -- LLM Provider Credentials --------------------------------------------------
# Only fill in the providers you want to use.  The service works with
# whichever credentials are present and returns a clear message for the rest.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_CLOUD_PROJECT=
VERTEX_AI_LOCATION=global

# -- Evaluation LLM defaults --------------------------------------------------
# Model string uses LiteLLM format: "<provider>/<model>"
# Examples: vertex_ai/gemini-3.1-flash-lite-preview
EVAL_LLM_MODEL=vertex_ai/gemini-3.1-flash-lite-preview
EVAL_LLM_TEMPERATURE=1.0
EVAL_EMBEDDING_MODEL=vertex_ai/text-embedding-004
EVAL_EMBEDDING_CACHE_SIZE=2048

# -- Stripe / Billing ----------------------------------------------------------
# Secret key: Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=
# Webhook signing secret: Stripe Dashboard → Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=
# Price IDs for the recurring subscription products
# Create these in Stripe Dashboard → Products → Add product → Recurring
STRIPE_PRO_PRICE_ID=
STRIPE_STARTUP_PRICE_ID=

# -- Logging -------------------------------------------------------------------
LOG_LEVEL=DEBUG
LOG_FORMAT=console
